generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CharacterSource {
  LOCAL
  NIVEL20
}

enum CharacterSyncStatus {
  NEVER_SYNCED
  SYNCING
  SYNCED
  ERROR
}

enum MappingProfileSource {
  NIVEL20
}

model Character {
  id               String              @id @default(cuid())
  name             String
  playerName       String?
  source           CharacterSource
  sourceUrl        String?
  sourceExternalId String?
  sourceLabel      String?
  syncStatus       CharacterSyncStatus @default(NEVER_SYNCED)
  lastSyncedAt     DateTime?
  syncError        String?
  importedData     Json?
  rawImportData    Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model MappingProfile {
  id                         String                    @id @default(cuid())
  source                     MappingProfileSource
  version                    Int
  rules                      Json
  customAttributeDefinitions Json
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  customDefinitions          CustomAttributeDefinition[]
}

model CustomAttributeDefinition {
  id               String         @id @default(cuid())
  mappingProfileId String
  key              String
  label            String
  type             String
  category         String
  description      String?
  visibleInSheet   Boolean        @default(true)
  visualOrder      Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  mappingProfile   MappingProfile @relation(fields: [mappingProfileId], references: [id], onDelete: Cascade)

  @@index([mappingProfileId])
  @@unique([mappingProfileId, key])
}
